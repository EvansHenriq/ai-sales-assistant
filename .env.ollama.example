# Profile for running the AI locally and FOR FREE with Ollama.
#
# Prereqs:
#   ollama pull llama3.2:3b
#   ollama pull nomic-embed-text
#
# Copy to `.env`. Verified working with: generation, BANT structured outputs,
# and embeddings. See the "Run for free with Ollama" section in the README.

ENVIRONMENT=local
LOG_LEVEL=INFO

# Ollama via its OpenAI-compatible endpoint (the API key is ignored but must be set).
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.2:3b
OPENAI_MODEL_CHEAP=llama3.2:3b
OPENAI_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
# Local CPU inference can be slow on the first call; allow a generous timeout.
OPENAI_TIMEOUT=120
# Ollama has no moderation endpoint, so disable output moderation.
MODERATION_ENABLED=false

# Database — start Postgres+pgvector via `docker compose ... up -d db`; the app
# runs locally and connects on localhost as the least-privilege app role.
DATABASE_URL=postgresql+asyncpg://app:change-me-app@localhost:5432/sales_assistant
