# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Application ---
ENVIRONMENT=local            # local | test | staging | production
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# The application connects with a least-privilege role.
# Superuser credentials are only used by migrations/admin tooling.
DATABASE_URL=postgresql+asyncpg://app:change-me-app@localhost:5432/sales_assistant

# --- OpenAI (never commit a real key) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4.1                     # strong model for generation
OPENAI_MODEL_CHEAP=gpt-4.1-mini          # cheaper model for classification/qualification
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=omni-moderation-latest

# --- Security ---
# Comma-separated list of allowed CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:3000
# Default per-client rate limit (slowapi syntax).
RATE_LIMIT=30/minute
